+            server.getScoreboard().storeToSaveDataIfDirty(server.getDataStorage().computeIfAbsent(ScoreboardSaveData.TYPE));
+
+            CompletableFuture<?> future = server.getDataStorage().saveSpecific(() -> {
+                final ArrayList<Class<? extends SavedData>> toSave = new ArrayList<>();
+
+                // both of these are SWMR, only mutatable on the global tick
+                if (autosaveConfig.autosaveScoreboards) {
+                    toSave.add(ScoreboardSaveData.class);
+                }
+                if (autosaveConfig.autosaveStopwatches) {
+                    toSave.add(Stopwatches.class);
+                }
+
+                // our pearl rewrite is threadsafe
+                if (autosaveConfig.autosavePearls) {
+                    toSave.add(EnderPearls.class);
+                }
+
+                // made threadsafe by Canvas
+                if (autosaveConfig.autosaveCustomBossEvents) {
+                    toSave.add(CustomBossEvents.class);
+                }
+
+                // only should be saved globally if affects all worlds
+                if (autosaveConfig.autosaveTime && GlobalConfiguration.get().time.affectsAllWorlds) {
+                    toSave.add(ServerClockManager.class);
+                }
+
+                return toSave;
+            });
+
+            // if sync we need to just join here. this shouldn't be done
+            // for autosave or every tick since this blocks waiting for completion
+
+            if (sync) {
+                future.join();
+            }
+        }
+    }
