+    public void autosaveSafeGlobalData(final boolean force, final boolean sync) {
+        ensureGlobalTickThread("Cannot save global data async");
+
+        final MinecraftServer server = MinecraftServer.getServer();
+        final io.canvasmc.canvas.GlobalConfiguration.Autosave autosaveConfig =
+            io.canvasmc.canvas.GlobalConfiguration.getInstance().autosave;
+
+        final long periodNanos = io.canvasmc.canvas.GlobalConfiguration.AUTOSAVE_SPAN.getValue().asNanoSpan();
+        if (periodNanos <= 0 && !force) return;
+        final long currTime = System.nanoTime();
+        final long last = LAST_GLOBAL_AUTOSAVE.longValue();
+
+        if (force || ((currTime - last) > periodNanos)) {
+            LAST_GLOBAL_AUTOSAVE.setValue(currTime);
+
+            // needs
+            // pearls - our rewrite
+            // scoreboards
+            // stopwatches
+            // custom boss events
+            // world clocks - only if affects all worlds
+
+            // we have to do this for the scoreboard system or else the scoreboard
+            // system won't actually save. see MinecraftServer#saveGlobalData
