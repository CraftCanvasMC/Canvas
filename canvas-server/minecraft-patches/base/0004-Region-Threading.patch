+                    }
+                    ++failures;
+                }
+            }
+
+            @Override
+            public boolean raisePriority(final Priority priority) {
+                int failures = 0;
+                for (Priority curr = this.getPriorityVolatile();;) {
+                    if (curr == Priority.COMPLETING) {
+                        return false;
+                    }
+
+                    if (curr.isHigherOrEqualPriority(priority)) {
