diff --git a/io/canvasmc/canvas/threadedregions/waypoints/RegionizedWaypointManager.java b/io/canvasmc/canvas/threadedregions/waypoints/RegionizedWaypointManager.java
new file mode 100644
index 0000000000000000000000000000000000000000..3fd785d6237c39fe0318256c5364f284dee34079
--- /dev/null
+++ b/io/canvasmc/canvas/threadedregions/waypoints/RegionizedWaypointManager.java
@@ -0,0 +1,282 @@
+package io.canvasmc.canvas.threadedregions.waypoints;
+
+import ca.spottedleaf.concurrentutil.collection.MultiThreadedQueue;
+import ca.spottedleaf.moonrise.common.util.TickThread;
+import io.canvasmc.canvas.GlobalConfiguration;
+import it.unimi.dsi.fastutil.objects.Object2ObjectMap;
+import java.util.HashSet;
+import java.util.Map;
+import java.util.Set;
+import net.minecraft.server.level.ServerLevel;
+import net.minecraft.server.level.ServerPlayer;
+import net.minecraft.server.waypoints.ServerWaypointManager;
+import net.minecraft.world.entity.LivingEntity;
+import net.minecraft.world.waypoints.WaypointTransmitter;
+import org.jspecify.annotations.NullMarked;
+import org.jspecify.annotations.Nullable;
+
+/**
+ * A region-threading-safe implementation of the {@link ServerWaypointManager}.
+ * <br></br>
+ * <b>Note:</b> With Folia's region threading implementation, most players will be spread out
+ * very far. As a result, the {@link net.minecraft.world.waypoints.WaypointTransmitter.EntityAzimuthConnection} will be
+ * the most used. This is optimized enough for region-threading, but this may be revisited in the future for even faster
+ * handling of this.
+ *
+ * @author dueris
+ */
+// TODO - PR to Paper
+@SuppressWarnings("CodeBlock2Expr")
+@NullMarked
+public class RegionizedWaypointManager extends ServerWaypointManager {
+
+    /**
+     * A rough distance scale that defines how often waypoint updates happen between faraway players.
+     * <p>
+     * The idea here is simple enough: as players get farther apart, updates become less frequent. This system works
+     * great for region threading, where players are usually scattered across huge distances.
+     * <br><br>
+     * In practice, it's used by {@link #shouldScheduleBasedOnDistance(LivingEntity, ServerPlayer)} like this:
+     * <pre>{@code
+     * probability = 1 / (1 + (distance / SCALE)^2)
+     * }</pre>
+     * That means a player right next to you almost always triggers an update, while someone thousands of blocks away
+     * might only do so occasionally — depending on how unlucky (or lucky) their random roll is.
+     * <br><br>
+     * A value of {@code 4000.0} is a decent middle ground. It avoids constant update spam across regions, but still
+     * keeps nearby players synced up. The ideal value probably depends on your server’s density and how forgiving you
+     * want the update delay to be.
+     */
+    private final double scale;
+
+    private final MultiThreadedQueue<WaypointTransmitter> waypoints = new MultiThreadedQueue<>();
+    private final MultiThreadedQueue<ServerPlayer> players = new MultiThreadedQueue<>();
+    private final ServerLevel level;
+
+    public RegionizedWaypointManager(final ServerLevel level) {
+        super(level);
+        this.level = level;
+        this.scale = level.canvasConfig().waypointUpdateScale;
+    }
+
+    private boolean shouldScheduleBasedOnDistance(final LivingEntity origin, final ServerPlayer target) {
+        final double scaled = origin.distanceTo(target) / scale;
+        return origin.getRandom().nextDouble() < (1.0 / (1.0 + (scaled * scaled)));
+    }
+
+    public boolean isLocatorBarDisabled() {
+        return !super.locatorBarEnabled || GlobalConfiguration.getInstance().disableLocatorBarInAllWorlds;
+    }
+
+    @Override
+    public void trackWaypoint(final WaypointTransmitter waypoint) {
+        if (!waypoints.contains(waypoint)) waypoints.add(waypoint);
+        if (isLocatorBarDisabled()) return;
+
+        for (final ServerPlayer trackedPlayer : players) {
+            trackedPlayer.getBukkitEntity().taskScheduler.scheduleOrExecute((ServerPlayer entityPlayer) -> {
+                createConnection(entityPlayer, waypoint);
+            });
+        }
+    }
+
+    @Override
+    public void updateWaypoint(final WaypointTransmitter waypoint) {
+        if (isLocatorBarDisabled()) return;
+        if (!waypoints.contains(waypoint)) return;
+
+        // the living entity class is what implements the transmitter interface,
+        // so we can safely cast to that
+
+        final LivingEntity updating = (LivingEntity) waypoint;
+
+        for (final ServerPlayer trackedPlayer : players) {
+            if (trackedPlayer == updating) continue;
+
+            if (updating.distanceTo(trackedPlayer) > 332.0F && !shouldScheduleBasedOnDistance(updating, trackedPlayer)) {
+                continue;
+            }
+
+            trackedPlayer.getBukkitEntity().taskScheduler.scheduleOrExecute((ServerPlayer entityPlayer) -> {
+                updateWaypoint(waypoint, entityPlayer);
+            });
+        }
+    }
+
+    @Override
+    public void untrackWaypoint(final WaypointTransmitter waypoint) {
+        for (final ServerPlayer trackedPlayer : players) {
+            trackedPlayer.getBukkitEntity().taskScheduler.scheduleOrExecute((ServerPlayer entityPlayer) -> {
+                disconnectWaypoint(waypoint, entityPlayer);
+            });
+        }
+
+        waypoints.remove(waypoint);
+    }
+
+    // note: this should be called on the "player" param
+    @Override
+    public void addPlayer(final ServerPlayer player) {
+        if (!players.contains(player)) players.add(player);
+
+        if (isLocatorBarDisabled()) return;
+        for (WaypointTransmitter waypoint : waypoints) {
+            createConnection(player, waypoint);
+        }
+
+        if (player.isTransmittingWaypoint()) {
+            trackWaypoint(player);
+        }
+    }
+
+    // note: this should be called on the "player" param
+    @Override
+    public void updatePlayer(final ServerPlayer player) {
+        if (isLocatorBarDisabled()) return;
+        player.getBukkitEntity().taskScheduler.scheduleOrExecute((ServerPlayer entityPlayer) -> {
+            final Object2ObjectMap<WaypointTransmitter, WaypointTransmitter.Connection> map = player.canvas$activeWaypoints;
+            // only contains null entries if has fewer callbacks than active waypoints
+            final @Nullable Runnable[] callbacks = new Runnable[map.size()];
+
+            int idx = 0;
+            for (final Map.Entry<WaypointTransmitter, WaypointTransmitter.Connection> entry : map.object2ObjectEntrySet()) {
+                final Runnable callback = updateConnection(entityPlayer, entry.getKey(), entry.getValue());
+                if (callback != null) {
+                    callbacks[idx] = callback;
+                    idx++;
+                }
+            }
+
+            for (final Runnable callback : callbacks) {
+                if (callback == null) break;
+                callback.run();
+            }
+
+            for (final WaypointTransmitter waypoint : waypoints) {
+                if (!map.containsKey(waypoint)) {
+                    createConnection(entityPlayer, waypoint);
+                }
+            }
+        });
+    }
+
+    // note: this should be called on the "player" param
+    @Override
+    public void removePlayer(final ServerPlayer player) {
+        breakConnection(player);
+
+        untrackWaypoint(player);
+        players.remove(player);
+    }
+
+    @Override
+    public void breakAllConnections() {
+        for (final ServerPlayer trackedPlayer : players) {
+            trackedPlayer.getBukkitEntity().taskScheduler.scheduleOrExecute((ServerPlayer entityPlayer) -> {
+                breakConnection(entityPlayer);
+            });
+        }
+    }
+
+    @Override
+    public void remakeConnections(final WaypointTransmitter waypoint) {
+        if (isLocatorBarDisabled()) return;
+        for (final ServerPlayer trackedPlayer : players) {
+            trackedPlayer.getBukkitEntity().taskScheduler.scheduleOrExecute((ServerPlayer entityPlayer) -> {
+                createConnection(entityPlayer, waypoint);
+            });
+        }
+    }
+
+    @Override
+    public Set<WaypointTransmitter> transmitters() {
+        return new HashSet<>(waypoints);
+    }
+
+    // note: this should be scheduled on the "player" param
+    private void updateWaypoint(final WaypointTransmitter waypoint, final ServerPlayer player) {
+        TickThread.ensureTickThread(player, "Cannot update waypoint async");
+        final Object2ObjectMap<WaypointTransmitter, WaypointTransmitter.Connection> map = player.canvas$activeWaypoints;
+        final WaypointTransmitter.Connection conn = map.get(waypoint);
+
+        if (conn != null) {
+            final Runnable callback = updateConnection(player, waypoint, conn);
+            if (callback != null) {
+                callback.run();
+            }
+        }
+        else createConnection(player, waypoint);
+    }
+
+    // note: this should be scheduled on the "player" param
+    private void disconnectWaypoint(final WaypointTransmitter waypoint, final ServerPlayer player) {
+        TickThread.ensureTickThread(player, "Cannot disconnect waypoint async");
+        final Object2ObjectMap<WaypointTransmitter, WaypointTransmitter.Connection> map = player.canvas$activeWaypoints;
+        final WaypointTransmitter.Connection conn = map.remove(waypoint);
+        if (conn != null) {
+            conn.disconnect();
+        }
+    }
+
+    // note: this should be scheduled on "player" param
+    private void createConnection(final ServerPlayer player, final WaypointTransmitter waypoint) {
+        if (player == waypoint) return;
+        TickThread.ensureTickThread(player, "Cannot create waypoint connection async");
+
+        final Object2ObjectMap<WaypointTransmitter, WaypointTransmitter.Connection> map = player.canvas$activeWaypoints;
+
+        waypoint.makeWaypointConnectionWith(player).ifPresentOrElse(connection -> {
+            map.put(waypoint, connection);
+            connection.connect();
+        }, () -> {
+            final WaypointTransmitter.Connection existing = map.remove(waypoint);
+            if (existing != null) {
+                existing.disconnect();
+            }
+        });
+    }
+
+    // note: this should be scheduled on the "player" param
+    @Nullable
+    private Runnable updateConnection(
+        final ServerPlayer player, final WaypointTransmitter waypoint, final WaypointTransmitter.Connection connection
+    ) {
+        if (player == waypoint) return null;
+        TickThread.ensureTickThread(player, "Cannot update waypoint connection async");
+
+        final Object2ObjectMap<WaypointTransmitter, WaypointTransmitter.Connection> map = player.canvas$activeWaypoints;
+
+        if (!connection.isBroken()) {
+            connection.update();
+        }
+        else {
+            var ref = new Object() {
+                @Nullable
+                Runnable returnRef;
+            };
+            waypoint.makeWaypointConnectionWith(player).ifPresentOrElse(newConn -> ref.returnRef = () -> {
+                newConn.connect();
+                map.put(waypoint, newConn);
+            }, () -> ref.returnRef = () -> {
+                connection.disconnect();
+                map.remove(waypoint);
+            });
+            return ref.returnRef;
+        }
+        return null;
+    }
+
+    public ServerLevel getLevel() {
+        return level;
+    }
+
+    // note: this should be scheduled on the "player" param
+    private static void breakConnection(final ServerPlayer player) {
+        TickThread.ensureTickThread(player, "Cannot update break connection async");
+        final Object2ObjectMap<WaypointTransmitter, WaypointTransmitter.Connection> map = player.canvas$activeWaypoints;
+        for (final WaypointTransmitter.Connection conn : map.values()) {
+            conn.disconnect();
+        }
+        map.clear();
+    }
+}
