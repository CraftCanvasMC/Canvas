+    public static final class ThreadedRegion<R extends ThreadedRegionData<R, S>, S extends ThreadedRegionSectionData> implements WorldRegionizer.ChunkRegion {
+
+        @Override
+        public long @NonNull [] getOwnedPackedChunkPositions() {
+            final boolean lock = this.regioniser.writeLockOwner != Thread.currentThread();
+            if (lock) {
+                this.regioniser.regionLock.readLock();
+            }
+            try {
+                final LongArrayList ret = new LongArrayList();
+                for (final ThreadedRegionSection<R, S> section : this.sectionByKey.values()) {
+                    ret.addAll(section.getChunks());
+                }
+
+                return ret.elements();
+            } finally {
+                if (lock) {
+                    this.regioniser.regionLock.tryUnlockRead();
+                }
+            }
+        }
+
+        @NonNull
+        @Override
+        public WorldRegionizer getRegionizer() {
+            return this.regioniser;
+        }
+
+        @NonNull
+        @Override
+        public State getState() {
+            return switch (this.state) {
+                case STATE_TRANSIENT -> State.TRANSIENT;
+                case STATE_READY -> State.READY;
+                case STATE_TICKING -> State.TICKING;
+                case STATE_DEAD -> State.DEAD;
+                default -> throw new IllegalStateException("Unknown state");
+            };
+        }
+
+        @NonNull
+        @Override
+        public RegionTickData getTickData() {
