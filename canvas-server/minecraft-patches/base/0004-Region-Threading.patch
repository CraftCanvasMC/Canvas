+            final long stealThresholdNS = TimeUnit.MILLISECONDS.toNanos(3L);
+            final long taskTimeSliceNS = TimeUnit.MILLISECONDS.toNanos(2L);
+
+            if (!MoonriseConstants.NUMA_ENABLE) {
