+    public void autosaveSafeWorldData(final boolean force, final boolean sync, final ServerLevel level) {
+        ensureGlobalTickThread("Cannot save global world data async");
+
+        final io.canvasmc.canvas.GlobalConfiguration.Autosave autosaveConfig =
+            io.canvasmc.canvas.GlobalConfiguration.getInstance().autosave;
+
+        final long periodNanos = io.canvasmc.canvas.GlobalConfiguration.AUTOSAVE_SPAN.getValue().asNanoSpan();
+        if (periodNanos <= 0 && !force) return;
+        final long currTime = System.nanoTime();
+        final long last = level.lastMapAutoSave;
+
+        if (force || ((currTime - last) > periodNanos)) {
+            level.lastMapAutoSave = currTime;
+
+            // needs
+            // world clocks
+            // world border
+            // raids
+            // weather
+            // game rules
+            // maps
+
+            // note: wandering trader data is regionized now, can't autosave
+
+            CompletableFuture<?> future = level.getDataStorage().saveSpecific(() -> {
+                final ArrayList<Class<? extends SavedData>> toSave = new ArrayList<>();
+
+                // maps is represented in 2 data types, the index and the item
+                if (autosaveConfig.autosaveMaps) {
+                    toSave.add(MapItemSavedData.class);
+                    toSave.add(MapIndex.class);
+                }
+
+                // only should be autosaved here if worlds have independent time
+                if (autosaveConfig.autosaveTime && !GlobalConfiguration.get().time.affectsAllWorlds) {
+                    toSave.add(ServerClockManager.class);
+                }
+
+                // TODO - world border - needs MASSIVE changes...
+                // TODO - raids - can we even do this?
+
+                // folia already only ticks this on the global tick and both canvas
+                // and folia have thread checks against modifying this data async, so this is fine
+                if (autosaveConfig.autosaveWeather) {
+                    toSave.add(WeatherData.class);
+                }
+                // already made threadsafe from folia, just needed the codec adjusted to copy the
+                // backing map to prevent exceptions or torn read/write issues
+                if (autosaveConfig.autosaveGamerules) {
+                    toSave.add(GameRuleMap.class);
+                }
+
+                // note: the dragon fight is autosaved on the region owning the fight in question.
+                //       this is because this is specific per-dimension and is also region-specific
+                //       in that dimension to a single region, and is ticked there too, so no point
+                //       in saving here if we don't even own the data in question
+
+                return toSave;
+            });
+
+            // if sync we need to just join here. this shouldn't be done
+            // for autosave or every tick since this blocks waiting for completion
+
+            if (sync) {
+                future.join();
+            }
+        }
+    }
