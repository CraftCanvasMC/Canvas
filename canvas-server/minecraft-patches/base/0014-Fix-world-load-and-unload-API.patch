index 1fd5a68fcb685646c5c28c8e94ffef5eb319d7d8..bc5e4f96ed258d0142c26b965a7226d05ba632cd 100644
--- a/net/minecraft/server/network/config/PrepareSpawnTask.java
+++ b/net/minecraft/server/network/config/PrepareSpawnTask.java
@@ -96,16 +96,32 @@ public class PrepareSpawnTask implements ConfigurationTask {
                 vanillaDefaultLevel = this.server.overworld();
             }
             ServerLevel serverLevel1;
+            boolean obtainedWorldStageLock = false; // Canvas - region threading
             if (resourceKey == null) {
                 serverLevel1 = vanillaDefaultLevel;
             } else {
                 serverLevel1 = this.server.getLevel(resourceKey);
-                if (serverLevel1 == null) {
+                // Canvas start - region threading
+                if (serverLevel1 != null) {
+                    serverLevel1.canvas$obtainWorldStageLock();
+                    obtainedWorldStageLock = true;
+                }
+                // if it is null, the dimension doesn't exist
+                if (serverLevel1 == null || serverLevel1.canvas$unloadTicket.isPresent()) {
+                    if (serverLevel1 != null) {
+                        // if we reach here, we are unloading
+                        serverLevel1.canvas$releaseWorldStageLock();
+                        obtainedWorldStageLock = false;
+                    }
+                    // the overworld cannot be unloaded because of the bukkit api rule
+                // Canvas end - region threading
                     LOGGER.warn("Unknown respawn dimension {}, defaulting to overworld", resourceKey);
                     serverLevel1 = vanillaDefaultLevel;
                 }
             }
             final ServerLevel serverLevel = serverLevel1;
+            serverLevel.canvas$incrementJoiningPlayers(nameAndId.name()); // Canvas - region threading
+            if (obtainedWorldStageLock) serverLevel.canvas$releaseWorldStageLock(); // Canvas - region threading
             // Paper end - move logic in Entity to here, to use bukkit supplied world UUID & reset to main world spawn if no valid world is found
             // Folia start - region threading
             CompletableFuture<Vec3> completableFuture = new java.util.concurrent.CompletableFuture<>();
