index 874da7be8423434b4c0ea429e4a88026f90f1338..e0bf9a3632f12a735bd02fb8dba7e3821afc5457 100644
--- a/net/minecraft/world/entity/player/Player.java
+++ b/net/minecraft/world/entity/player/Player.java
@@ -1370,6 +1370,28 @@ public abstract class Player extends Avatar implements ContainerUser {
     @Override
     protected void preRemove(RemovalReason reason) {
         super.preRemove(reason);
+        // Canvas start - restore detached fishing hook portal behavior
+        if (reason == RemovalReason.CHANGED_DIMENSION && io.canvasmc.canvas.Config.INSTANCE.combat.restoreDetachedFishingHookPortalBug) {
+            if (this.fishing != null) {
+                final boolean hasEnderPearlInHookChunk = this.fishing.canvas$hasEnderPearlInChunkSnapshot();
+                final boolean shouldPreserveDetachedState = !hasEnderPearlInHookChunk;
+                boolean hasNearbyOtherPlayer = false;
+                if (this.level() instanceof net.minecraft.server.level.ServerLevel serverLevel) {
+                    final int simulationDistance = serverLevel.serverLevelData.canvas$distanceConfig.simulationDistanceOrDefault();
+                    final double simulationDistanceBlocks = simulationDistance * 16.0;
+                    final double simulationDistanceSq = simulationDistanceBlocks * simulationDistanceBlocks;
+                    for (net.minecraft.server.level.ServerPlayer other : serverLevel.players()) {
+                        if (other != this && !other.isRemoved() && this.distanceToSqr(other) <= simulationDistanceSq) {
+                            hasNearbyOtherPlayer = true;
+                            break;
+                        }
+                    }
+                }
+                this.fishing.canvas$markPortalTransferState(shouldPreserveDetachedState, this.getUUID(), hasNearbyOtherPlayer);
+            }
+            return;
+        }
+        // Canvas end - restore detached fishing hook portal behavior
         this.fishing = null;
     }
     // Folia end - region threading
