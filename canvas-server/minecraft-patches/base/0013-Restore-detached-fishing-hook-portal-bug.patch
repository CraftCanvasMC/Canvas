+    // Canvas start - restore detached fishing hook portal behavior
+    private boolean canvas$tryHandleDetachedHook(@Nullable Player playerOwner) {
+        if (!this.canvas$detachedPortalBugActive) {
+            return false;
+        }
+        if (this.canvas$shouldRealizeDetachedHook(playerOwner)) {
+            this.canvas$realizeDetachedHook(playerOwner);
+            return true;
+        }
+        ServerPlayer loadingPlayer = this.canvas$getChunkLoadingPlayer();
+        if (loadingPlayer != null && !canvas$isPortalTransitionActive(loadingPlayer)) {
+            this.canvas$scheduleOrRealizeDetachedHook(loadingPlayer);
+            return true;
+        }
+        return false;
+    }
+
+    private boolean canvas$shouldRealizeDetachedHook(@Nullable Player playerOwner) {
+        if (playerOwner == null || canvas$isPortalTransitionActive(playerOwner)) {
+            return false;
+        }
+        if (ca.spottedleaf.moonrise.common.util.TickThread.isTickThreadFor(playerOwner)
+            && playerOwner.level().dimension() == this.level().dimension()) {
+            return true;
+        }
+        if (this.canvas$forceRealizeAfterCrossDimensionArrival && playerOwner.level().dimension() != this.level().dimension()) {
+            return true;
+        }
+        return this.canvas$detachedOwnerUuid != null
+            && this.canvas$detachedOwnerUuid.equals(playerOwner.getUUID())
+            && this.getOwnerRaw() != playerOwner;
+    }
+
+    private void canvas$scheduleOrRealizeDetachedHook(ServerPlayer player) {
+        if (ca.spottedleaf.moonrise.common.util.TickThread.isTickThreadFor(player)) {
+            this.canvas$realizeDetachedHook(player);
+        } else if (!this.canvas$realizeScheduled) {
+            this.canvas$realizeScheduled = true;
+            player.scheduleToOrRun(() -> this.scheduleToOrRun(() -> {
+                this.canvas$realizeScheduled = false;
+                if (this.canvas$detachedPortalBugActive && !this.isRemoved() && !canvas$isPortalTransitionActive(player)) {
+                    this.canvas$realizeDetachedHook(player);
+                }
+            }));
+        }
+    }
+
+    private @Nullable ServerPlayer canvas$getReloggedOwner() {
+        if (this.canvas$detachedOwnerUuid == null) {
+            return null;
+        }
+        net.minecraft.server.MinecraftServer server = net.minecraft.server.MinecraftServer.getServer();
+        return server == null ? null : server.getPlayerList().getPlayer(this.canvas$detachedOwnerUuid);
+    }
+
+    private void canvas$realizeDetachedHook(Player playerOwner) {
+        if (this.hookedIn != null
+            && ca.spottedleaf.moonrise.common.util.TickThread.isTickThreadFor(this.hookedIn)
+            && !this.hookedIn.isRemoved()
+            && this.hookedIn.canInteractWithLevel()) {
+            this.pullEntity(this.hookedIn);
+        }
+        this.discard(org.bukkit.event.entity.EntityRemoveEvent.Cause.DESPAWN); // CraftBukkit - add Bukkit remove cause
+        this.canvas$detachedPortalBugActive = false;
+        this.canvas$realizeScheduled = false;
+        this.canvas$detachedOwnerUuid = null;
+        this.canvas$forceRealizeAfterCrossDimensionArrival = false;
+    }
+
+    private static boolean canvas$isPortalTransitionActive(Player player) {
+        if (player.isRemoved() && player.getRemovalReason() == Entity.RemovalReason.CHANGED_DIMENSION) {
+            return true;
+        }
+        return player instanceof ServerPlayer serverPlayer && serverPlayer.isChangingDimension();
+    }
+
+    private ServerPlayer canvas$getChunkLoadingPlayer() {
+        if (!(this.level() instanceof ServerLevel serverLevel)) {
+            return null;
+        }
+        ca.spottedleaf.moonrise.common.list.ReferenceList<ServerPlayer> players =
+            serverLevel.moonrise$getNearbyPlayers().getPlayers(this.chunkPosition(), ca.spottedleaf.moonrise.common.misc.NearbyPlayers.NearbyMapType.VIEW_DISTANCE);
+        if (players == null || players.size() == 0) {
+            return null;
+        }
+        ServerPlayer[] raw = players.getRawDataUnchecked();
+        for (int i = 0, len = players.size(); i < len; ++i) {
+            ServerPlayer player = raw[i];
+            if (player != null && !player.isRemoved()) {
+                return player;
+            }
+        }
+        return null;
+    }
+
+    private boolean canvas$hasEnderPearlInCurrentChunk() {
+        net.minecraft.world.level.ChunkPos chunkPos = this.chunkPosition();
+        double minX = chunkPos.x << 4;
+        double minZ = chunkPos.z << 4;
+        double maxX = minX + 16.0;
+        double maxZ = minZ + 16.0;
+        net.minecraft.world.phys.AABB chunkBounds = new net.minecraft.world.phys.AABB(
+            minX,
+            this.level().getMinY(),
+            minZ,
+            maxX,
+            this.level().getMaxY(),
+            maxZ
+        );
+        return !this.level()
+            .getEntitiesOfClass(
+                net.minecraft.world.entity.projectile.throwableitemprojectile.ThrownEnderpearl.class,
+                chunkBounds,
+                entity -> !entity.isRemoved()
+            )
+            .isEmpty();
+    }
+
+    public boolean canvas$hasEnderPearlInChunkSnapshot() {
+        return this.canvas$chunkHasEnderPearl;
+    }
+
+    public void canvas$markPortalTransferState(boolean active, java.util.UUID ownerUuid, boolean forceRealizeAfterCrossDimensionArrival) {
+        this.canvas$detachedPortalBugActive = active;
+        this.canvas$realizeScheduled = false;
+        this.canvas$detachedOwnerUuid = active ? ownerUuid : null;
+        this.canvas$forceRealizeAfterCrossDimensionArrival = active && forceRealizeAfterCrossDimensionArrival;
+    }
+    // Canvas end - restore detached fishing hook portal behavior
+
     public static enum FishHookState {
         FLYING,
         HOOKED_IN_ENTITY,
