+    private void savePlayers() {
+        net.minecraft.server.players.PlayerList playerList = MinecraftServer.getServer().getPlayerList();
+        LOGGER.info("Removing players");
+        // waiting for 100ms is a stupid fix
+        List<java.util.concurrent.CompletableFuture<Void>> futures = new ArrayList<>();
+        // prepare futures
+        for (final ServerPlayer serverPlayer : playerList.getPlayers()) {
+            final net.minecraft.network.Connection connection = serverPlayer.connection.connection;
+            if (connection.channel == null || !connection.channel.isOpen()) continue;
+            java.util.concurrent.CompletableFuture<Void> future = new java.util.concurrent.CompletableFuture<>();
+            connection.channel.closeFuture().addListener(f -> future.complete(null));
+            futures.add(future);
+        }
+
+        // save pearls
+        final org.apache.commons.lang3.mutable.MutableInt savedPearlCount = new org.apache.commons.lang3.mutable.MutableInt(0);
+        final java.util.Map<ThreadedRegionizer.ThreadedRegion<TickRegions.TickRegionData, TickRegions.TickRegionSectionData>, List<com.mojang.datafixers.util.Pair<java.util.UUID, net.minecraft.world.entity.projectile.throwableitemprojectile.ThrownEnderpearl>>>
+            region2Pearls = com.google.common.collect.Maps.newHashMap();
+        final boolean removeDuplicatePearl = io.canvasmc.canvas.GlobalConfiguration.getInstance().vanillaFixes.pearlDuplication;
+
+        for (final ServerPlayer entityPlayer : MinecraftServer.getServer().getPlayerList().getPlayers()) {
+            final java.util.UUID uuid = entityPlayer.getUUID();
+            final java.util.Set<net.minecraft.world.entity.projectile.throwableitemprojectile.ThrownEnderpearl> toSave = entityPlayer.getEnderPearls();
+
+            // we have to save manually like this since technically pearls
+            // can be anywhere in the world during shutdown, including out of
+            // the region of the existing player(stasis chambers for example).
+
+            // because of that, we need to collect all pearls and make sure we
+            // save them all with the proper region set
+
+            for (final net.minecraft.world.entity.projectile.throwableitemprojectile.ThrownEnderpearl thrownEnderpearl : toSave) {
+                if (thrownEnderpearl.level().paperConfig().misc.legacyEnderPearlBehavior) continue;
+
+                final int chunkX = thrownEnderpearl.getBlockX() >> 4;
+                final int chunkZ = thrownEnderpearl.getBlockZ() >> 4;
+                final ThreadedRegionizer.ThreadedRegion<TickRegions.TickRegionData, TickRegions.TickRegionSectionData>
+                    regionAtChunk = entityPlayer.level().regioniser.getRegionAtUnsynchronised(chunkX, chunkZ);
+                if (regionAtChunk == null) {
+                    // if region isn't loaded, skip
+                    continue;
+                }
+
+                region2Pearls.computeIfAbsent(
+                    regionAtChunk,
+                    (_) -> new ArrayList<>()
+                ).add(new com.mojang.datafixers.util.Pair<>(uuid, thrownEnderpearl));
+            }
+        }
+
+        region2Pearls.forEach((region, listOfPearls) -> {
+            ChunkPos center = null;
+            try {
+                this.shuttingDown = region;
+                center = region.getCenterChunk();
+                for (final com.mojang.datafixers.util.Pair<java.util.UUID, net.minecraft.world.entity.projectile.throwableitemprojectile.ThrownEnderpearl> pair : listOfPearls) {
+                    MinecraftServer.getServer().pearls.addPearl(pair.getFirst(), pair.getSecond());
+                    if (removeDuplicatePearl) {
+                        pair.getSecond().setRemoved(Entity.RemovalReason.UNLOADED_WITH_PLAYER, org.bukkit.event.entity.EntityRemoveEvent.Cause.PLAYER_QUIT);
+                    }
+                    savedPearlCount.increment();
+                }
+            } catch (Throwable thrown) {
+                LOGGER.error("Failed to save pearls for region around chunk " + center + " in level '" + region.regioniser.world.getWorld().getName() + "'", thrown);
+            } finally {
+                this.shuttingDown = null;
+            }
+        });
+
+        final int total = savedPearlCount.intValue();
+        if (total > 0) {
+            LOGGER.info("Saved {} in-flight pearl{}", total, total > 1 ? "s" : "");
+        }
+
+        // now, remove players and wait
+        playerList.removeAll(MinecraftServer.getServer().isRestarting);
+
+        // wait for player removal
+        if (!futures.isEmpty()) {
+            if (io.canvasmc.canvas.util.Util.waitFor(java.util.concurrent.CompletableFuture.allOf(futures.toArray(new java.util.concurrent.CompletableFuture[0])),
+                java.util.concurrent.TimeUnit.SECONDS, 20)) {
+                LOGGER.info("Players removed");
+            } else {
+                LOGGER.warn("Players did not all get removed within 20 seconds, proceeding with shutdown anyways");
+            }
+        }
+
+        // wait for pearl save, then wait for connection shutdown
+        MinecraftServer.getServer().pearls.save(null).join();
+        MinecraftServer.getServer().getConnection().stop();
+    }
+    // Canvas end - region threading
 
