             this.setDetailsFrom(this.hiddenEffect);
             this.hiddenEffect = this.hiddenEffect.hiddenEffect;
-            return true;
-        } else {
-            return false;
-        }
+        } while (this.duration == 0 && this.hiddenEffect != null);
+
+        return true;
+        // Paper end - Fix MC-259832
     }
 
