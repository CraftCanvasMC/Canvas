From: Dueris <duerismc@gmail.com>
Date: Fri, 19 Jun 2026 21:35:59 -0700
Subject: [PATCH] Canvas RegionizedWorldData


diff --git a/io/papermc/paper/threadedregions/RegionizedWorldData.java b/io/papermc/paper/threadedregions/RegionizedWorldData.java
index 17e01669171d777cdf578836703c84fa7797023f..a88f5d7ebd46b6fcbe065caefa00cd648a4b2209 100644
--- a/io/papermc/paper/threadedregions/RegionizedWorldData.java
+++ b/io/papermc/paper/threadedregions/RegionizedWorldData.java
@@ -323,6 +323,20 @@ public final class RegionizedWorldData {
     };
 
     public final ServerLevel world;
+    // Canvas start - canvas regionized data
+
+    // this is because I don't want to deal with an insane amount of diff constantly
+    // because of canvas adding a ton of regionized data
+
+    private io.canvasmc.canvas.world.CanvasRegionizedWorldData canvasWorldData;
+
+    public io.canvasmc.canvas.world.CanvasRegionizedWorldData getCanvasWorldData() {
+        if (this.canvasWorldData == null) {
+            this.canvasWorldData = io.canvasmc.canvas.world.CanvasRegionizedWorldData.getCurrentWorldData();
+        }
+        return canvasWorldData;
+    }
+    // Canvas end - canvas regionized data
 
     private RegionizedServer.WorldLevelData tickData;
 
