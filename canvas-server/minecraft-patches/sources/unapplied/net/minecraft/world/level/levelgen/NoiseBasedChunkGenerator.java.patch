@@ -356,6 +356,15 @@ public final class NoiseBasedChunkGenerator extends ChunkGenerator {
         int cellYMin = Mth.floorDiv(minY, noiseSettings.getCellHeight());
         int cellCountY = Mth.floorDiv(noiseSettings.height(), noiseSettings.getCellHeight());
         return cellCountY <= 0 ? CompletableFuture.completedFuture(centerChunk) : CompletableFuture.supplyAsync(() -> {
+            // Canvas start - optimize noise gen
+            if (io.canvasmc.canvas.GlobalConfiguration.getInstance().chunkSystem.optimizeNoiseGeneration) {
+                // remove the rest of this bs, we don't need it
+                @Nullable ChunkAccess chunkWithNoise = this.doFill(
+                    blender, structureManager, randomState, centerChunk, cellYMin, cellCountY);
+
+                return chunkWithNoise;
+            }
+            // Canvas end - optimize noise gen
             int topSectionIndex = centerChunk.getSectionIndex(cellCountY * noiseSettings.getCellHeight() - 1 + minY);
             int bottomSectionIndex = centerChunk.getSectionIndex(minY);
             Set<LevelChunkSection> sections = Sets.newHashSet();
@@ -441,7 +450,11 @@ public final class NoiseBasedChunkGenerator extends ChunkGenerator {
 
                                 state = this.debugPreliminarySurfaceLevel(noiseChunk, posX, posY, posZ, state);
                                 if (state != AIR && !SharedConstants.debugVoidTerrain(centerChunk.getPos())) {
-                                    section.setBlockState(xInSection, yInSection, zInSection, state, false);
+                                    // Canvas start - optimize noise gen
+                                    if (io.canvasmc.canvas.GlobalConfiguration.getInstance().chunkSystem.optimizeNoiseGeneration && section.states.strategy != null) {
+                                        canvas$populateNoiseWrapSetBlockStateOperation(section, xInSection, yInSection, zInSection, state, false);
+                                    } else section.setBlockState(xInSection, yInSection, zInSection, state, false);
+                                    // Canvas end - optimize noise gen
                                     oceanFloor.update(xInSection, posY, zInSection, state);
                                     worldSurface.update(xInSection, posY, zInSection, state);
                                     if (aquifer.shouldScheduleFluidUpdate() && !state.getFluidState().isEmpty()) {
@@ -461,6 +474,26 @@ public final class NoiseBasedChunkGenerator extends ChunkGenerator {
         noiseChunk.stopInterpolation();
         return centerChunk;
     }
+    // Canvas start - optimize noise gen
+
+    private BlockState canvas$populateNoiseWrapSetBlockStateOperation(final LevelChunkSection section, final int sectionX, final int sectionY, final int sectionZ, final BlockState state, final boolean checkThreading) {
+        section.nonEmptyBlockCount += 1;
+
+        if (!state.getFluidState().isEmpty()) {
+            section.tickingFluidCount += 1;
+        }
+
+        if (state.isRandomlyTicking()) {
+            section.tickingBlockCount += 1;
+        }
+
+        section.states.getAndSetUnchecked(
+            sectionX, sectionY, sectionZ, state
+        );
+
+        return state;
+    }
+    // Canvas end - optimize noise gen
 
     private BlockState debugPreliminarySurfaceLevel(final NoiseChunk noiseChunk, final int posX, final int posY, final int posZ, BlockState state) {
         if (SharedConstants.DEBUG_AQUIFERS && posZ >= 0 && posZ % 4 == 0) {
