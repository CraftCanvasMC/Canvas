+            }
+            long visitKey = encodeSlopeNode(testPos, directionx.getOpposite());
+            if (visited.add(visitKey)) {
+                queue.add(new FlowingFluid.SlopeDistanceNode(testPos, pass, directionx.getOpposite(), testState));
+            }
+        }
+
+        int slopeFindDistance = this.getSlopeFindDistance(level);
         int lowest = 1000;
 
-        for (Direction direction : Direction.Plane.HORIZONTAL) {
