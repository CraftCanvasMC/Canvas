diff --git a/net/minecraft/world/level/block/state/BlockBehaviour.java b/net/minecraft/world/level/block/state/BlockBehaviour.java
index 42918460ae0fffdde1e7fab5baec6a3662b10be7..bd54d410093f62ff8d4441bcde892a54286ac015 100644
--- a/net/minecraft/world/level/block/state/BlockBehaviour.java
+++ b/net/minecraft/world/level/block/state/BlockBehaviour.java
@@ -445,6 +445,9 @@ public abstract class BlockBehaviour implements FeatureElement {
         private final boolean ignitedByLava;
         @Deprecated
         private final boolean liquid;
+        public boolean canvas$isWater = false; // Canvas - optimize fluid pushing
+        public boolean canvas$isBubble = false; // Canvas - optimize fluid pushing
+        public boolean canvas$isLava = false; // Canvas - optimize fluid pushing
         @Deprecated
         private boolean legacySolid;
         private final PushReaction pushReaction;
@@ -488,6 +491,24 @@ public abstract class BlockBehaviour implements FeatureElement {
         private boolean emptyCollisionShape;
         private boolean emptyConstantCollisionShape;
         private VoxelShape constantCollisionShape;
+        // Canvas start - optimize path type cache
+        // inspired by Cache-block-state-tags patch from Leaf
+        public byte pathType; // 8bit, better this enum, as it only has 25 values
+        public int tagFlag; // caches blockstate flags
+
+        public void canvas$initCaches() {
+            this.tagFlag = io.canvasmc.canvas.world.block.BlockTags.init(asState());
+            this.pathType = (byte) net.minecraft.world.level.pathfinder.WalkNodeEvaluator.canvas$getPathTypeFromBlockState(this.asState()).ordinal();
+        }
+
+        public static void canvas$initPathTypeCache() {
+            for (Block block : BuiltInRegistries.BLOCK) {
+                for (BlockState blockState : block.getStateDefinition().getPossibleStates()) {
+                    blockState.canvas$initCaches();
+                }
+            }
+        }
+        // Canvas end - optimize path type cache
 
         private static void initCaches(final VoxelShape shape, final boolean neighbours) {
             ((ca.spottedleaf.moonrise.patches.collisions.shape.CollisionVoxelShape)shape).moonrise$isFullBlock();
@@ -594,6 +615,9 @@ public abstract class BlockBehaviour implements FeatureElement {
         protected boolean shapeExceedsCube = true; // Paper - moved from actual method to here
         public void initCache() {
             this.fluidState = this.owner.getFluidState(this.asState());
+            this.canvas$isWater = this.is(Blocks.WATER); // Canvas - optimize fluid pushing
+            this.canvas$isBubble = this.is(Blocks.BUBBLE_COLUMN); // Canvas - optimize fluid pushing
+            this.canvas$isLava = this.is(Blocks.LAVA); // Canvas - optimize fluid pushing
             this.isRandomlyTicking = this.owner.isRandomlyTicking(this.asState());
             if (!this.getBlock().hasDynamicShape()) {
                 this.cache = new BlockBehaviour.BlockStateBase.Cache(this.asState());
