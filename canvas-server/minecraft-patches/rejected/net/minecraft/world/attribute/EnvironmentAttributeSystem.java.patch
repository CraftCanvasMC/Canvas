From fb2fa76bcfb03ba2831bd257c68fc51821e86ead Mon Sep 17 00:00:00 2001
From: File <noreply+automated@papermc.io>
Date: Sun, 20 Apr 1997 15:37:42 +0200
Subject: [PATCH] canvas File Patches


diff --git a/net/minecraft/world/attribute/EnvironmentAttributeSystem.java b/net/minecraft/world/attribute/EnvironmentAttributeSystem.java
index 309dfbf987988413a26602d67261f7f1da9371dc..306d0908589a9ac3f308e77936193bb60893293a 100644
--- a/net/minecraft/world/attribute/EnvironmentAttributeSystem.java
+++ b/net/minecraft/world/attribute/EnvironmentAttributeSystem.java
@@ -62,7 +62,19 @@ public class EnvironmentAttributeSystem implements EnvironmentAttributeReader {
     static void addDefaultLayers(EnvironmentAttributeSystem.Builder builder, Level level) {
         RegistryAccess registryAccess = level.registryAccess();
         BiomeManager biomeManager = level.getBiomeManager();
-        LongSupplier longSupplier = level::getDayTime;
+        // Canvas start - region threading
+        LongSupplier longSupplier = () -> {
+            io.papermc.paper.threadedregions.RegionizedWorldData worldData =
+                io.papermc.paper.threadedregions.TickRegionScheduler.getCurrentRegionizedWorldData();
+            // tbh worldData shouldn't be null, but just to be sure we check
+            if (worldData == null || worldData.world != level) {
+                // world not ours, get day time safely
+                return level.getLevelData().getDayTime();
+            }
+            // on correct world, get daytime from region data
+            return worldData.getTickData().dayTime();
+        };
+        // Canvas end - region threading
         addDimensionLayer(builder, level.dimensionType());
         addBiomeLayer(builder, registryAccess.lookupOrThrow(Registries.BIOME), biomeManager);
         level.dimensionType().timelines().forEach(holder -> builder.addTimelineLayer((Holder<Timeline>)holder, longSupplier));
