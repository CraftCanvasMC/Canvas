+    // Canvas start - optimize noise gen
+
+    private BlockState canvas$populateNoiseWrapSetBlockStateOperation(LevelChunkSection chunkSection, int chunkSectionBlockPosX, int chunkSectionBlockPosY, int chunkSectionBlockPosZ, BlockState blockState, boolean lock) {
+        chunkSection.nonEmptyBlockCount += 1;
+
+        if (!blockState.getFluidState().isEmpty()) {
+            chunkSection.tickingFluidCount += 1;
+        }
+
+        if (blockState.isRandomlyTicking()) {
+            chunkSection.tickingBlockCount += 1;
+        }
+
+        if (blockState.canvas$isWater) {
+            chunkSection.canvas$waterCount++;
+        }
+
+        if (blockState.canvas$isBubble) {
+            chunkSection.canvas$bubbleCount++;
+        }
+
+        if (blockState.canvas$isLava) {
+            chunkSection.canvas$lavaCount++;
+        }
+
+        chunkSection.states.getAndSetUnchecked(
+            chunkSectionBlockPosX, chunkSectionBlockPosY, chunkSectionBlockPosZ, blockState
+        );
+
+        return blockState;
+    }
+    // Canvas end - optimize noise gen
 
