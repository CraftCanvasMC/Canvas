Subject: [PATCH] canvas File Patches


diff --git a/net/minecraft/world/entity/monster/zombie/ZombieVillager.java b/net/minecraft/world/entity/monster/zombie/ZombieVillager.java
index 8af935a11a0988f10a2908f6337504f7f6e13d1b..5ea6a9eba649f886a64110e19579d0ce920640e0 100644
--- a/net/minecraft/world/entity/monster/zombie/ZombieVillager.java
+++ b/net/minecraft/world/entity/monster/zombie/ZombieVillager.java
@@ -264,6 +264,16 @@ public class ZombieVillager extends Zombie implements VillagerDataHolder {
                 if (!this.isSilent()) {
                     level.levelEvent(null, LevelEvent.SOUND_ZOMBIE_CONVERTED, this.blockPosition(), 0);
                 }
+                // Canvas start - MC-200418
+                if (
+                    io.canvasmc.canvas.Config.INSTANCE.fixes.mc200418
+                        && mob.isPassenger()
+                        && mob.getVehicle() instanceof net.minecraft.world.entity.animal.chicken.Chicken
+                        && mob.isBaby())
+                {
+                    mob.removeVehicle();
+                }
+                // Canvas end - MC-200418
                 // CraftBukkit start
             }, org.bukkit.event.entity.EntityTransformEvent.TransformReason.CURED, org.bukkit.event.entity.CreatureSpawnEvent.SpawnReason.CURED // CraftBukkit
         );
