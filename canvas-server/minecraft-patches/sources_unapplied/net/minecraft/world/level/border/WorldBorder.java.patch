From fb2fa76bcfb03ba2831bd257c68fc51821e86ead Mon Sep 17 00:00:00 2001
From: File <noreply+automated@papermc.io>
Date: Sun, 20 Apr 1997 15:37:42 +0200
Subject: [PATCH] canvas File Patches


diff --git a/net/minecraft/world/level/border/WorldBorder.java b/net/minecraft/world/level/border/WorldBorder.java
index 8ae712c4f5365c43df4e7e1017f6ce93c24ffb2f..8cebc2d275e3faac61db619dc91ef81803de53ea 100644
--- a/net/minecraft/world/level/border/WorldBorder.java
+++ b/net/minecraft/world/level/border/WorldBorder.java
@@ -391,6 +391,8 @@ public class WorldBorder extends SavedData {
         WorldBorder.BorderExtent update();
 
         VoxelShape getCollisionShape();
+        long canvas$getIdentifier(); // Canvas - optimize block entities
+        boolean canvas$isMoving(); // Canvas - optimize block entities
     }
 
     class MovingBorderExtent implements WorldBorder.BorderExtent {
@@ -414,6 +416,18 @@ public class WorldBorder extends SavedData {
             this.size = d;
             this.previousSize = d;
         }
+        // Canvas start - optimize block entities
+
+        @Override
+        public long canvas$getIdentifier() {
+            return Long.MIN_VALUE;
+        }
+
+        @Override
+        public boolean canvas$isMoving() {
+            return true;
+        }
+        // Canvas end - optimize block entities
 
         @Override
         public double getMinX(float partialTick) {
@@ -649,7 +663,22 @@ public class WorldBorder extends SavedData {
                 ),
                 BooleanOp.ONLY_FIRST
             );
+        // Canvas start - optimize block entities
+            this.canvas$identifier = canvas$computeIdentifier(this.size, centerX, centerZ);
+        }
+        private long canvas$identifier;
+
+        private static long canvas$computeIdentifier(double size, double centerX, double centerZ) {
+            long hash = 1469598103934665603L;
+            hash ^= Double.doubleToRawLongBits(size);
+            hash *= 1099511628211L;
+            hash ^= Double.doubleToRawLongBits(centerX);
+            hash *= 1099511628211L;
+            hash ^= Double.doubleToRawLongBits(centerZ);
+            hash *= 1099511628211L;
+            return hash;
         }
+        // Canvas end - optimize block entities
 
         @Override
         public void onAbsoluteMaxSizeChange() {
@@ -670,5 +699,17 @@ public class WorldBorder extends SavedData {
         public VoxelShape getCollisionShape() {
             return this.shape;
         }
+        // Canvas start - optimize block entities
+
+        @Override
+        public long canvas$getIdentifier() {
+            return canvas$identifier;
+        }
+
+        @Override
+        public boolean canvas$isMoving() {
+            return false;
+        }
+        // Canvas end - optimize block entities
     }
 }
