From 56fbeba69dc02a23c55fcd9bf06e3cae1da93bce Mon Sep 17 00:00:00 2001
From: File <noreply+automated@papermc.io>
Date: Sun, 20 Apr 1997 15:37:42 +0200
Subject: [PATCH] canvas File Patches


diff --git a/net/minecraft/network/codec/ByteBufCodecs.java b/net/minecraft/network/codec/ByteBufCodecs.java
index 8844da770c5b9be6adda0b115ce10b55f3271018..6f3f646308a74362ea7cd94ae94f48961ee0fe3d 100644
--- a/net/minecraft/network/codec/ByteBufCodecs.java
+++ b/net/minecraft/network/codec/ByteBufCodecs.java
@@ -782,9 +782,35 @@ public interface ByteBufCodecs {
 
             @Override
             public void encode(final ByteBuf output, final JsonElement value) {
+                // Canvas start - no chat reports
+                if (io.canvasmc.canvas.GlobalConfiguration.getInstance().chat.disableChatReporting && this.canvas$isServerStatusElement(value)) {
+                    com.google.gson.JsonObject object = value.getAsJsonObject();
+                    object.addProperty("preventsChatReports", true);
+
+                    String string = GSON.toJson(object);
+                    Utf8String.write(output, string, 32767);
+                    return;
+                }
+                // Canvas end - no chat reports
                 String payload = GSON.toJson(value);
                 Utf8String.write(output, payload, maxStringLength);
             }
+            // Canvas start - no chat reports
+
+            private boolean canvas$isServerStatusElement(JsonElement element) {
+                if (!element.isJsonObject())
+                    return false;
+
+                com.google.gson.JsonObject object = element.getAsJsonObject();
+
+                if (!object.has("version") || !object.get("version").isJsonObject())
+                    return false;
+
+                com.google.gson.JsonObject version = object.get("version").getAsJsonObject();
+
+                return version.has("name") && version.has("protocol");
+            }
+            // Canvas end - no chat reports
         };
     }
 }
