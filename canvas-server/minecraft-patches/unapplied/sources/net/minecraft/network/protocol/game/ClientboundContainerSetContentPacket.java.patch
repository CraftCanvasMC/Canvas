@@ -30,6 +30,7 @@ public record ClientboundContainerSetContentPacket(int containerId, int stateId,
 
     @Override
     public boolean packetTooLarge(net.minecraft.network.Connection manager) {
+        if (io.canvasmc.canvas.GlobalConfiguration.getInstance().networking.disablePaperPacketOverflowContainerFix) return false; // Canvas - container overflow config
         for (int i = 0 ; i < this.items.size() ; i++) {
             manager.send(new ClientboundContainerSetSlotPacket(this.containerId, this.stateId, i, this.items.get(i)));
