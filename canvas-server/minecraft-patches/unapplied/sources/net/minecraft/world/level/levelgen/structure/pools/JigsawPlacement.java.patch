+                                            if (io.canvasmc.canvas.GlobalConfiguration.getInstance().chunkSystem.structureOptimizations.enable) {
+                                                if (parentBounds instanceof io.canvasmc.canvas.util.structure.TrojanVoxelShape trojanVoxelShape) {
