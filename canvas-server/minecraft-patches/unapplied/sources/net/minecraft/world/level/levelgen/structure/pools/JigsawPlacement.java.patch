-                                            if (!Shapes.joinIsNotEmpty(
-                                                childrenFree.get(), Shapes.create(AABB.of(targetBB).deflate(0.25)), BooleanOp.ONLY_SECOND
-                                            )) {
+                                            // Canvas start - optimize structure gen
