Date: Sun, 20 Apr 1997 15:37:42 +0200
Subject: [PATCH] canvas File Patches


diff --git a/net/minecraft/world/level/block/CropBlock.java b/net/minecraft/world/level/block/CropBlock.java
index b8456dc5cb428593701d07837ba5c8ae063af876..859d83a184167747a368d72a89812e3fd3391e08 100644
--- a/net/minecraft/world/level/block/CropBlock.java
+++ b/net/minecraft/world/level/block/CropBlock.java
@@ -164,6 +164,7 @@ public class CropBlock extends VegetationBlock implements BonemealableBlock {
     }
 
     protected static boolean hasSufficientLight(final LevelReader level, final BlockPos pos) {
+        if (level instanceof ServerLevel serverLevel && serverLevel.canvasConfig().farming.cropsIgnoreLightCheck) return true; // Canvas - crops ignore light check config
         return level.getRawBrightness(pos, 0) >= 8;
     }
 
