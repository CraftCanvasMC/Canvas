+        SERVER_IO_GROUP = ((io.canvasmc.canvas.world.chunk.BalancedChunkSystem) IO_POOL).createChunkOrderedStreamGroup();
+
+        LOGGER.info("Running LS ChunkSystem with {} worker threads and {} io threads", workerThreads, ioThreads);
