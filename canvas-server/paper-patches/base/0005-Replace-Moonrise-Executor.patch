+    private static void setupAggressiveChunkSystem(final int workerThreads, final int ioThreads) {
+        if (WORKER_POOL != null && IO_POOL != null) {
+
+            // we just need to adjust the thread count, cannot recreate instances
+            // this is most likely result of a reload or startup
+
+            WORKER_POOL.adjustThreadCount(workerThreads);
+            IO_POOL.adjustThreadCount(ioThreads);
+
+            LOGGER.info("Adjusted LS ChunkSystem to {} worker threads and {} io threads", workerThreads, ioThreads);
+            return;
